{
  "name": "server",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/server.ts --outfile server",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^7.0.4",
    "@booking-for-all/auth": "workspace:*",
    "@booking-for-all/db": "workspace:*",
    "@polar-sh/sdk": "^0.36.1",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "fastify": "^5.6.1",
    "fastify-raw-body": "^5.0.0",
    "fastify-type-provider-zod": "^5.1.0",
    "resend": "^6.1.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/supertest": "^6.0.3",
    "pino-pretty": "^11.3.0",
    "supertest": "^7.1.4",
    "tsdown": "catalog:",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  }
