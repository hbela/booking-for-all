{
  "name": "server",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "sentry:release": "sentry-cli releases files \"$SENTRY_RELEASE\" upload-sourcemaps ./dist --project booking-for-all-fastify-api",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/server.ts --outfile server",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@booking-for-all/auth": "workspace:*",
    "@booking-for-all/db": "workspace:*",
    "@booking-for-all/i18n": "workspace:*",
    "@fastify/cors": "^10.1.0",
    "@fastify/env": "^5.0.3",
    "@fastify/multipart": "^9.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^7.0.4",
    "@polar-sh/sdk": "^0.36.1",
    "@sentry/node": "^10.24.0",
    "@sentry/profiling-node": "^10.24.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "fastify": "^5.6.1",
    "fastify-plugin": "^5.0.1",
    "fastify-raw-body": "^5.0.0",
    "fastify-type-provider-zod": "^5.1.0",
    "i18next": "^23.15.1",
    "i18next-fs-backend": "^2.3.1",
    "form-data": "^4.0.1",
    "qrcode": "^1.5.4",
    "resend": "^6.1.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.3",
    "pino-pretty": "^11.3.0",
    "supertest": "^7.1.4",
    "tsdown": "catalog:",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "^3.2.4"
  }
}
