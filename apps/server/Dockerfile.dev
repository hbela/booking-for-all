# syntax=docker/dockerfile:1.6
# Development Dockerfile for server
FROM node:22-bullseye

WORKDIR /app

# Install global toolchain
RUN npm install -g pnpm@10 turbo@2

# Copy the workspace
COPY . .

# Build-time environment (can be overridden with --build-arg)
ARG NODE_ENV=development
ENV NODE_ENV=${NODE_ENV}

# Install deps & build server
# In development, we might want source maps and other dev features
RUN pnpm install --frozen-lockfile \
 && pnpm --filter @booking-for-all/db exec prisma generate --no-engine \
 && pnpm turbo run build --filter=server

# Runtime environment defaults (can be overridden by Coolify)
ENV NODE_ENV=development \
    PORT=3000 \
    HOST=0.0.0.0

EXPOSE 3000

CMD ["pnpm", "--filter", "server", "run", "start"]

