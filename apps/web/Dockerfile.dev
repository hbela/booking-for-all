# syntax=docker/dockerfile:1.6
# Development Dockerfile for web
FROM node:22-bullseye

WORKDIR /app

# Install workspace toolchain
RUN npm install -g pnpm@10 turbo@2

# Install Chrome/Chromium dependencies for Puppeteer prerendering
RUN apt-get update && apt-get install -y \
    chromium \
    chromium-sandbox \
    ca-certificates \
    fonts-liberation \
    libappindicator3-1 \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

# Set Chrome path for Puppeteer
ENV CHROME_PATH=/usr/bin/chromium
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Copy the monorepo
COPY . .

# Build-time environment (can be overridden with --build-arg)
ARG NODE_ENV=development
ARG VITE_ENVIRONMENT=development
ENV NODE_ENV=${NODE_ENV}
ENV VITE_ENVIRONMENT=${VITE_ENVIRONMENT}

# Install dependencies and build the web app
# In development, Vite will include source maps and dev optimizations
# TEMPORARILY: Using build:no-prerender to debug blank page issue
RUN pnpm install --frozen-lockfile \
 && pnpm --filter web run build:no-prerender

# Runtime environment defaults (can be overridden by Coolify)
ENV NODE_ENV=development \
    HOST=0.0.0.0 \
    PORT=4173

EXPOSE 4173

# Serve the prebuilt Vite app using custom Express server
# Note: Coolify may override this with the start command from service settings
CMD ["pnpm", "--filter", "web", "run", "start"]

