      {
        "name": "Provider Creation API",
        "description": "Creates a provider account with user credentials. Validates owner membership, department ownership, creates user account with temporary password, creates provider record, adds provider as organization member, sends welcome email, and attempts to enable organization. Requires authentication and owner role.",
        "files": [
          "apps/server/src/features/providers/routes.ts"
        ],
        "api_doc": {
          "openapi": "3.0.0",
          "info": {
            "title": "Provider Creation API",
            "version": "1.0.0"
          },
          "paths": {
            "/api/providers/create-user": {
              "post": {
                "summary": "Create provider with user account",
                "description": "Creates a new provider account with user credentials. Validates that the owner is a member of the organization, verifies the department belongs to the organization, creates a user account with temporary password, creates provider record, adds provider as organization member, sends welcome email, and attempts to enable organization if conditions are met. Requires authentication and owner role via Better Auth session cookies.",
                "tags": [
                  "Providers"
                ],
                "security": [
                  {
                    "sessionAuth": []
                  }
                ],
                "requestBody": {
                  "required": true,
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "required": [
                          "name",
                          "email",
                          "organizationId",
                          "departmentId"
                        ],
                        "properties": {
                          "name": {
                            "type": "string",
                            "minLength": 1,
                            "description": "Provider's full name"
                          },
                          "email": {
                            "type": "string",
                            "format": "email",
                            "description": "Provider's email address"
                          },
                          "organizationId": {
                            "type": "string",
                            "minLength": 1,
                            "description": "ID of the organization"
                          },
                          "departmentId": {
                            "type": "string",
                            "minLength": 1,
                            "description": "ID of the department"
                          },
                          "bio": {
                            "type": "string",
                            "description": "Provider's bio (optional)"
                          },
                          "specialization": {
                            "type": "string",
                            "description": "Provider's specialization (optional)"
                          }
                        }
                      }
                    }
                  }
                },
                "responses": {
                  "201": {
                    "description": "Provider created successfully",
                    "content": {
                      "application/json": {
                        "schema": {
                          "type": "object",
                          "properties": {
                            "provider": {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "type": "string"
                                },
                                "userId": {
                                  "type": "string"
                                },
                                "departmentId": {
                                  "type": "string"
                                }
                              }
                            },
                            "user": {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "type": "string"
                                },
                                "name": {
                                  "type": "string"
                                },
                                "email": {
                                  "type": "string"
                                }
                              }
                            },
                            "tempPassword": {
                              "type": "string"
                            }
                          }
                        }
                      }
                    }
                  },
                  "400": {
                    "description": "Bad request - User with this email already exists"
                  },
                  "401": {
                    "description": "Unauthorized - Authentication required"
                  },
                  "403": {
                    "description": "Forbidden - Owner access required or not a member of the organization"
                  },
                  "404": {
                    "description": "Department not found or does not belong to this organization"
                  },
                  "500": {
                    "description": "Internal server error"
                  }
                }
              }
            },
            "/api/providers": {
              "post": {
                "summary": "Create provider record",
                "description": "Creates a provider record for an existing user. Requires authentication and owner role via Better Auth session cookies. Attempts to enable organization if conditions are met.",
                "tags": [
                  "Providers"
                ],
                "security": [
                  {
                    "sessionAuth": []
                  }
                ],
                "requestBody": {
                  "required": true,
                  "content": {
                    "application/json": {
                      "schema": {
                        "type": "object",
                        "properties": {
                          "userId": {
                            "type": "string",
                            "description": "User ID"
                          },
                          "departmentId": {
                            "type": "string",
                            "description": "Department ID"
                          },
                          "bio": {
                            "type": "string",
                            "description": "Provider's bio"
                          },
                          "specialization": {
                            "type": "string",
                            "description": "Provider's specialization"
                          }
                        }
                      }
                    }
                  }
                },
                "responses": {
                  "201": {
                    "description": "Provider created successfully",
                    "content": {
                      "application/json": {
                        "schema": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string"
                            },
                            "userId": {
                              "type": "string"
                            },
                            "departmentId": {
                              "type": "string"
                            },
                            "bio": {
                              "type": "string",
                              "nullable": true
                            },
                            "specialization": {
                              "type": "string",
                              "nullable": true
                            }
                          }
                        }
                      }
                    }
                  },
                  "401": {
                    "description": "Unauthorized - Authentication required"
                  },
                  "403": {
                    "description": "Forbidden - Owner access required"
                  },
                  "500": {
                    "description": "Internal server error"
                  }
                }
              }
            }
          },
          "components": {
            "securitySchemes": {
              "sessionAuth": {
                "type": "apiKey",
                "in": "cookie",
                "name": "better-auth.session_token",
                "description": "Better Auth session cookie. Authenticate via POST /api/auth/sign-in/email first to obtain session cookies."
              }
            }
          }
        }
