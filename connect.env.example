# connect.php Environment Configuration Template
# Copy this file to .env in the same directory as connect.php
# NEVER commit the actual .env file to version control

# Environment configuration
PHP_ENV=development
# Options: development, production
# In development, allows localhost origins for easier local testing

# Backend API Configuration
VERIFY_URL=http://localhost:3000/api/external/verify
# URL of your Express/Node.js backend API verify endpoint

FRONTEND_REDIRECT=http://localhost:3001/login
# Frontend URL where users will be redirected after authentication

# CORS Configuration
ALLOWED_CORS_ORIGINS=http://localhost:3001,http://localhost:5173
# Comma-separated list of allowed origins for CORS
# In production, replace with your actual domain(s)

# ============================================
# Organization Configuration
# ============================================
# Add as many organizations as needed using the pattern:
# {SLUG}_API_KEY, {SLUG}_NAME, {SLUG}_ORG_ID

# Example: Wellness Center organization
WELLNESS_API_KEY=your_wellness_api_key_here
WELLNESS_NAME=Wellness Center
WELLNESS_ORG_ID=8f79bdba-7095-4a47-90c7-a2e839cc413b

# Example: Medical Clinic organization
MEDICAL_API_KEY=your_medical_api_key_here
MEDICAL_NAME=Medical Clinic
MEDICAL_ORG_ID=your-medical-org-id-here

# Example: Fitness Center organization
FITNESS_API_KEY=your_fitness_api_key_here
FITNESS_NAME=Fitness Center
FITNESS_ORG_ID=your-fitness-org-id-here

# ============================================
# Adding New Organizations
# ============================================
# To add a new organization, simply add three environment variables:
#
# SLUG_API_KEY=generated_api_key_from_admin_panel
# SLUG_NAME=Display Name
# SLUG_ORG_ID=organization_id_from_database
#
# Example for a "Spa Center" organization:
# SPA_API_KEY=abc123xyz789
# SPA_NAME=Spa Center
# SPA_ORG_ID=spa-center-org-id
#
# Example for MediCare organization:
# MEDICARE_API_KEY=your_medicare_api_key_here
# MEDICARE_NAME=MediCare
# MEDICARE_ORG_ID=your-medicare-org-id-here
#
# The system will automatically discover and load it!
# No code changes required.

