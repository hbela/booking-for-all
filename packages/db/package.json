{
  "name": "@booking-for-all/db",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "db:push": "prisma db push --schema=./prisma/schema/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema/schema.prisma",
    "db:generate": "prisma generate --schema=./prisma/schema/schema.prisma",
    "db:generate:dev": "prisma generate --schema=./prisma/schema/schema.prisma",
    "db:generate:prod": "prisma generate --no-engine --schema=./prisma/schema/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema=./prisma/schema/schema.prisma",
    "db:sync:production": "node scripts/sync-production.mjs",
    "db:deploy": "node scripts/deploy-migrations.mjs",
    "db:fix-drift": "node scripts/fix-drift.mjs",
    "db:migrate-data": "tsx scripts/migrate-sqlite-to-postgres.ts",
    "db:migrate-auth-method": "tsx migrate-auth-method.ts"
  },
  "devDependencies": {
    "prisma": "^6.17.0",
    "tsdown": "catalog:",
    "tsx": "^4.20.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "@prisma/extension-accelerate": "^2.0.2",
    "dotenv": "catalog:",
    "zod": "catalog:"
  }
}
